# Database
DB_PASSWORD=your_strong_password_here

# External API Keys
MORALIS_API_KEY=your_moralis_key
SCORECHAIN_API_KEY=your_scorechain_key
VIRUSTOTAL_API_KEY=your_virustotal_key

# CORS: список через запятую, поддерживает шаблоны "*" и "https://*.example.com"
# Примеры:
#   CORS_ALLOWED_ORIGINS=https://cryptosentinel.duckdns.org
#   CORS_ALLOWED_ORIGINS=https://*.mydomain.tld,http://localhost:*
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*,https://*.duckdns.org
